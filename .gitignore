# build output
dist/
.output/

# dependencies
node_modules/

# generated types
.astro/

# environment variables (contains secrets — never commit)
.env
.env.*
!.env.example
.dev.vars

# wrangler / miniflare local state
.wrangler/
.mf/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# macOS / editor
.DS_Store
*.local

# Claude Code local settings (machine-specific)
.claude/settings.local.json

# stray Windows redirect artifact
nul

# large videos — hosted on Cloudflare Stream, not committed (see TODO URLs in pages)
public/video/

# saved source webpages used as blog import sources (scripts/import-from-file.mjs)
# — e.g. "Save As → Webpage, Complete" produces a .html plus a *_files/ folder
*_files/
/BBC Three Counties Radio*.html
