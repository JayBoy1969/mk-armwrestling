---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: string;
}

const {
  title,
  description = 'MK Armwrestling - Strength. Power. Victory.',
  image = '/images/hero.jpg',
  ogType = 'website',
} = Astro.props;

const fullTitle = `${title} | MK Armwrestling`;
// Build absolute URLs from the configured site domain (falls back to the request
// URL) so canonicals / og:image point at mkarmwrestling.co.uk regardless of host.
const base = Astro.site ?? Astro.url;
const ogImage = new URL(image, base).href;
const canonicalURL = new URL(Astro.url.pathname, base).href;
const siteUrl = base.origin;

const orgSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SportsClub',
      '@id': `${siteUrl}/#organization`,
      name: 'MK Armwrestling',
      alternateName: 'Milton Keynes Armwrestling',
      url: siteUrl,
      logo: `${siteUrl}/favicon.svg`,
      image: `${siteUrl}/images/hero.jpg`,
      sport: 'Armwrestling',
      areaServed: 'Milton Keynes',
      address: {
        '@type': 'PostalAddress',
        name: 'Muscle Hut',
        streetAddress: 'Muscle Hut, 11 Bridge Turn Ave, Old Wolverton',
        addressLocality: 'Milton Keynes',
        addressRegion: 'Buckinghamshire',
        postalCode: 'MK12 5QL',
        addressCountry: 'GB',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 52.065695,
        longitude: -0.810131,
      },
      openingHoursSpecification: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: 'Thursday',
        opens: '19:00',
        closes: '21:00',
      },
      sameAs: [
        'https://www.instagram.com/mkarmwrestling/',
        'https://www.facebook.com/groups/5536349236',
        'https://www.youtube.com/@miltonkeynesarmwrestling',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      name: 'MK Armwrestling',
      url: siteUrl,
      publisher: { '@id': `${siteUrl}/#organization` },
    },
  ],
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="MK Armwrestling" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(orgSchema).replace(/</g, '\\u003c')} />
  </head>
  <body class="bg-dark-bg min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
