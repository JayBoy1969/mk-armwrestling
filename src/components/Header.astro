---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/athletes', label: 'Athletes' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-dark-bg/95 backdrop-blur-sm border-b border-dark-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-12 h-12 bg-blood-red rounded-lg flex items-center justify-center group-hover:bg-blood-red-light transition-colors">
          <span class="font-heading text-2xl font-bold text-white">MK</span>
        </div>
        <div class="hidden sm:block">
          <span class="font-heading text-xl text-white tracking-wider">MK ARMWRESTLING</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`font-heading text-lg tracking-wide transition-colors hover:text-blood-red ${
              currentPath === link.href ? 'text-blood-red' : 'text-text-secondary'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-text-secondary hover:text-white transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden bg-dark-surface border-t border-dark-border">
    <nav class="flex flex-col py-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`px-6 py-3 font-heading text-lg tracking-wide transition-colors hover:bg-dark-card hover:text-blood-red ${
            currentPath === link.href ? 'text-blood-red bg-dark-card' : 'text-text-secondary'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
