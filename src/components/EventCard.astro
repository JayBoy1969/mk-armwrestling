---
interface Props {
  title: string;
  date: string;
  location: string;
  description?: string;
  status?: 'upcoming' | 'completed' | 'live';
}

const { title, date, location, description, status = 'upcoming' } = Astro.props;

const statusStyles = {
  upcoming: 'bg-blood-red text-white',
  completed: 'bg-dark-border text-text-muted',
  live: 'bg-green-600 text-white animate-pulse',
};

const statusLabels = {
  upcoming: 'Upcoming',
  completed: 'Completed',
  live: 'Live Now',
};
---

<div class="bg-dark-card rounded-xl border border-dark-border p-6 hover:border-blood-red/50 transition-all">
  <div class="flex items-start justify-between mb-4">
    <div>
      <span class={`inline-block px-3 py-1 rounded-full text-xs font-heading tracking-wider ${statusStyles[status]}`}>
        {statusLabels[status]}
      </span>
    </div>
  </div>

  <h3 class="font-heading text-2xl text-white mb-3">{title}</h3>

  <div class="space-y-2 mb-4">
    <div class="flex items-center gap-2 text-text-secondary">
      <svg class="w-4 h-4 text-blood-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <span class="text-sm">{date}</span>
    </div>
    <div class="flex items-center gap-2 text-text-secondary">
      <svg class="w-4 h-4 text-blood-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <span class="text-sm">{location}</span>
    </div>
  </div>

  {description && (
    <p class="text-text-muted text-sm">{description}</p>
  )}
</div>
