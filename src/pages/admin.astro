---
export const prerender = false;
import { isAuthenticated } from '../lib/auth';

const authed = await isAuthenticated(Astro.cookies);
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - MK Armwrestling</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: #0a0a0a;
      color: #fff;
      min-height: 100vh;
    }
    .container { max-width: 900px; margin: 0 auto; padding: 2rem; }
    h1, h2, h3, label { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.05em; }
    h1 { font-size: 2.5rem; color: #fff; margin-bottom: 2rem; }
    h2 { font-size: 1.5rem; color: #8B0000; margin-bottom: 1rem; }

    /* Login */
    #login-form { max-width: 400px; margin: 4rem auto; }
    #login-form input {
      width: 100%;
      padding: 1rem;
      background: #1a1a1a;
      border: 1px solid #333;
      border-radius: 0.5rem;
      color: #fff;
      font-size: 1rem;
      margin-bottom: 1rem;
    }
    #login-form input:focus { outline: none; border-color: #8B0000; }

    /* Admin Panel */
    .form-group { margin-bottom: 1.5rem; }
    .form-group label { display: block; margin-bottom: 0.5rem; color: #999; font-size: 0.9rem; }
    .form-group input, .form-group textarea {
      width: 100%;
      padding: 1rem;
      background: #1a1a1a;
      border: 1px solid #333;
      border-radius: 0.5rem;
      color: #fff;
      font-size: 1rem;
    }
    .form-group input:focus, .form-group textarea:focus { outline: none; border-color: #8B0000; }
    .form-group textarea { min-height: 200px; resize: vertical; }

    .btn {
      padding: 1rem 2rem;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.1rem;
      letter-spacing: 0.05em;
      border: none;
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-primary { background: #8B0000; color: #fff; }
    .btn-primary:hover { background: #a50000; }
    .btn-primary:disabled { background: #444; cursor: not-allowed; }
    .btn-secondary { background: #333; color: #fff; margin-left: 1rem; }
    .btn-secondary:hover { background: #444; }

    .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .btn-logout {
      background: transparent;
      border: 1px solid #333;
      color: #999;
      padding: 0.5rem 1rem;
      border-radius: 0.5rem;
      font-family: 'Bebas Neue', sans-serif;
      letter-spacing: 0.05em;
      cursor: pointer;
    }
    .btn-logout:hover { border-color: #8B0000; color: #fff; }

    /* Preview */
    #preview-area {
      margin-top: 2rem;
      padding: 2rem;
      background: #1a1a1a;
      border: 1px solid #333;
      border-radius: 0.5rem;
      display: none;
    }
    #preview-area h3 { color: #fff; font-size: 1.8rem; margin-bottom: 0.5rem; }
    #preview-area .date { color: #8B0000; font-family: 'Bebas Neue', sans-serif; margin-bottom: 1rem; }
    #preview-area .excerpt { color: #8B0000; font-style: italic; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid #333; }
    #preview-area .body { color: #999; line-height: 1.7; }
    #preview-area .body p { margin-bottom: 1rem; }
    #preview-area img { max-width: 100%; border-radius: 0.5rem; margin-bottom: 1rem; }

    .status { padding: 1rem; border-radius: 0.5rem; margin-bottom: 1rem; }
    .status.success { background: #1a3a1a; color: #4ade80; }
    .status.error { background: #3a1a1a; color: #f87171; }
    .status.loading { background: #1a2a3a; color: #60a5fa; }

    .back-link { display: inline-block; color: #8B0000; text-decoration: none; margin-bottom: 2rem; }
    .back-link:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="container">
    <a href="/" class="back-link">&larr; Back to Site</a>
    <h1>Blog Admin</h1>

    <!-- Login Form -->
    <div id="login-form" style={authed ? 'display: none;' : ''}>
      <h2>Login Required</h2>
      <input type="password" id="password" placeholder="Enter password" autocomplete="current-password">
      <button class="btn btn-primary" onclick="login()">Login</button>
      <div id="login-error" class="status error" style="display: none;"></div>
    </div>

    <!-- Admin Panel -->
    <div id="admin-panel" style={authed ? 'display: block;' : 'display: none;'}>
      <div class="panel-header">
        <h2>Generate a Post</h2>
        <button class="btn-logout" onclick="logout()">Log out</button>
      </div>

      <div id="status-message"></div>

      <div class="form-group">
        <label>Topic</label>
        <input type="text" id="topic" placeholder="e.g., WAF UK Armwrestling Championships 2026">
      </div>

      <div class="form-group">
        <label>Image search term (optional)</label>
        <input type="text" id="image-search-term" placeholder="e.g., strength training man — overrides the auto image search">
      </div>

      <div class="form-group">
        <label>Guidance / extra context (optional)</label>
        <textarea id="guidance" style="min-height: 100px;" placeholder="e.g., focus on his left hand technique, mention his competition record"></textarea>
      </div>

      <div>
        <button class="btn btn-primary" id="generate-btn" onclick="generatePost()">Generate Post</button>
      </div>

      <div id="preview-area">
        <h2>Preview</h2>
        <img id="preview-image" src="" alt="">
        <h3 id="preview-title"></h3>
        <div class="date" id="preview-date"></div>
        <div class="excerpt" id="preview-excerpt"></div>
        <div class="body" id="preview-body"></div>
        <div style="margin-top: 2rem;">
          <button class="btn btn-primary" onclick="publishPost()">Publish Post</button>
          <button class="btn btn-secondary" onclick="clearPreview()">Clear</button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    let currentPost = null;

    async function login() {
      const password = document.getElementById('password').value;
      const errorEl = document.getElementById('login-error');
      errorEl.style.display = 'none';

      try {
        const res = await fetch('/api/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password })
        });
        if (res.ok) {
          // Cookie is set; reload so the server renders the admin panel.
          window.location.reload();
        } else {
          const data = await res.json().catch(() => ({}));
          errorEl.textContent = data.error || 'Incorrect password';
          errorEl.style.display = 'block';
        }
      } catch (e) {
        errorEl.textContent = 'Login failed. Please try again.';
        errorEl.style.display = 'block';
      }
    }

    async function logout() {
      try {
        await fetch('/api/logout', { method: 'POST' });
      } finally {
        window.location.reload();
      }
    }

    const passwordInput = document.getElementById('password');
    if (passwordInput) {
      passwordInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') login();
      });
    }

    function showStatus(message, type) {
      const el = document.getElementById('status-message');
      el.className = 'status ' + type;
      el.textContent = message;
      el.style.display = 'block';
    }

    function hideStatus() {
      document.getElementById('status-message').style.display = 'none';
    }

    async function generatePost() {
      const topic = document.getElementById('topic').value.trim();
      if (!topic) {
        showStatus('Please enter a topic', 'error');
        return;
      }
      const imageSearchTerm = document.getElementById('image-search-term').value.trim();
      const guidance = document.getElementById('guidance').value.trim();

      const btn = document.getElementById('generate-btn');
      btn.disabled = true;
      btn.textContent = 'Generating...';
      showStatus('Generating post with AI... This may take a moment.', 'loading');

      try {
        const response = await fetch('/api/generate-post', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ topic, imageSearchTerm, guidance })
        });

        const data = await response.json();

        if (response.status === 401) {
          showStatus('Session expired. Please log in again.', 'error');
          setTimeout(() => window.location.reload(), 1200);
          return;
        }
        if (!response.ok) {
          throw new Error(data.error || 'Failed to generate post');
        }

        currentPost = data;

        document.getElementById('preview-image').src = data.image;
        document.getElementById('preview-title').textContent = data.title;
        document.getElementById('preview-date').textContent = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
        document.getElementById('preview-excerpt').textContent = data.excerpt;
        document.getElementById('preview-body').innerHTML = data.body.split('\n\n').map(p => `<p>${p}</p>`).join('');
        document.getElementById('preview-area').style.display = 'block';

        hideStatus();
      } catch (error) {
        showStatus('Error: ' + error.message, 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Generate Post';
      }
    }

    async function publishPost() {
      if (!currentPost) {
        showStatus('No post to publish', 'error');
        return;
      }

      showStatus('Publishing post...', 'loading');

      try {
        const response = await fetch('/api/publish-post', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(currentPost)
        });

        const data = await response.json();

        if (response.status === 401) {
          showStatus('Session expired. Please log in again.', 'error');
          setTimeout(() => window.location.reload(), 1200);
          return;
        }
        if (!response.ok) {
          throw new Error(data.error || 'Failed to publish post');
        }

        showStatus('Post published successfully! View it at /blog/' + data.slug, 'success');
        clearPreview();
        document.getElementById('topic').value = '';
        document.getElementById('image-search-term').value = '';
        document.getElementById('guidance').value = '';
      } catch (error) {
        showStatus('Error: ' + error.message, 'error');
      }
    }

    function clearPreview() {
      currentPost = null;
      document.getElementById('preview-area').style.display = 'none';
    }
  </script>
</body>
</html>
