---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';

const faqs = [
  {
    question: 'How do I join MK Armwrestling?',
    answer: 'Contact us through the form below or visit one of our training sessions. We welcome athletes of all skill levels.',
  },
  {
    question: 'Do I need experience to start?',
    answer: 'No prior experience is required! Our coaches work with beginners to teach proper technique and build strength safely.',
  },
  {
    question: 'What are the training fees?',
    answer: 'Contact us for current membership rates. We offer monthly memberships and drop-in options.',
  },
  {
    question: 'How do I register for competitions?',
    answer: 'Competition registration is handled through our team. Reach out to us and we\'ll guide you through the process.',
  },
];
---

<Layout title="Contact">
  <Hero
    title="Contact Us"
    subtitle="Get in touch with us. We'd love to hear from you."
    backgroundImage="/images/gallery-4.jpg"
    imagePosition="center center"
  />

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div>
          <SectionHeader title="Send Us a Message" centered={false} />
          <form id="contact-form" class="space-y-6" novalidate>
            <div
              id="contact-status"
              class="rounded-lg"
              style="display: none; padding: 1rem; font-size: 0.95rem;"
            ></div>

            <!-- Honeypot: hidden from people, bots tend to fill it. -->
            <div aria-hidden="true" style="position: absolute; left: -9999px; top: -9999px;">
              <label for="website">Website</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-text-secondary mb-2">
                  Name
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded-lg text-white placeholder-text-muted focus:outline-none focus:border-blood-red transition-colors"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-text-secondary mb-2">
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded-lg text-white placeholder-text-muted focus:outline-none focus:border-blood-red transition-colors"
                  placeholder="your@email.com"
                />
              </div>
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-text-secondary mb-2">
                Subject
              </label>
              <select
                id="subject"
                name="subject"
                class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded-lg text-white focus:outline-none focus:border-blood-red transition-colors"
              >
                <option value="general">General Inquiry</option>
                <option value="training">Training & Membership</option>
                <option value="competition">Competition Information</option>
                <option value="sponsorship">Sponsorship</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-text-secondary mb-2">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded-lg text-white placeholder-text-muted focus:outline-none focus:border-blood-red transition-colors resize-none"
                placeholder="How can we help you?"
              ></textarea>
            </div>

            <button
              type="submit"
              id="contact-submit"
              class="w-full px-6 py-4 bg-blood-red text-white font-heading text-lg tracking-wide rounded-lg hover:bg-blood-red-light transition-colors disabled:opacity-60"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- FAQ -->
        <div>
          <SectionHeader title="Frequently Asked Questions" centered={false} />
          <div class="space-y-4">
            {faqs.map(faq => (
              <details class="group bg-dark-card rounded-xl border border-dark-border">
                <summary class="flex items-center justify-between p-4 cursor-pointer">
                  <span class="font-heading text-white">{faq.question}</span>
                  <svg class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-4 pb-4">
                  <p class="text-text-secondary">{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section (Placeholder) -->
  <section class="py-20 bg-dark-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        title="Find Us"
        subtitle="Visit our training facility."
      />
      <div class="rounded-2xl border border-dark-border overflow-hidden">
        <iframe
          title="Map to Muscle Hut, Wolverton, Milton Keynes"
          src="https://maps.google.com/maps?q=Muscle%20Hut%20Wolverton%20Milton%20Keynes&output=embed"
          class="w-full h-96 block"
          style="border: 0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const form = document.getElementById('contact-form');
      if (!form) return;
      const statusEl = document.getElementById('contact-status');
      const submitBtn = document.getElementById('contact-submit');

      function showStatus(message, type) {
        if (!statusEl) return;
        if (!message) {
          statusEl.style.display = 'none';
          statusEl.textContent = '';
          return;
        }
        statusEl.textContent = message;
        statusEl.style.display = 'block';
        if (type === 'success') {
          statusEl.style.background = '#13261a';
          statusEl.style.color = '#4ade80';
        } else {
          statusEl.style.background = '#2a1414';
          statusEl.style.color = '#f87171';
        }
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault();

        const payload = {
          name: document.getElementById('name').value.trim(),
          email: document.getElementById('email').value.trim(),
          subject: document.getElementById('subject').value,
          message: document.getElementById('message').value.trim(),
          website: document.getElementById('website').value
        };

        if (!payload.name || !payload.email || !payload.message) {
          showStatus('Please fill in your name, email, and message.', 'error');
          return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending...';
        showStatus('', '');

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const result = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(result.error || 'Something went wrong.');
          showStatus("Thanks! Your message has been sent — we'll be in touch soon.", 'success');
          form.reset();
        } catch (err) {
          showStatus('Sorry, your message could not be sent. Please try again later.', 'error');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message';
        }
      });
    })();
  </script>
</Layout>
