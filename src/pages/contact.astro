---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';

const contactInfo = [
  {
    title: 'Email',
    value: 'info@mkarmwrestling.com',
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
  {
    title: 'Phone',
    value: '+1 (555) 123-4567',
    icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
  },
  {
    title: 'Location',
    value: 'MK Training Facility, Downtown',
    icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
  },
];

const faqs = [
  {
    question: 'How do I join MK Armwrestling?',
    answer: 'Contact us through the form below or visit one of our training sessions. We welcome athletes of all skill levels.',
  },
  {
    question: 'Do I need experience to start?',
    answer: 'No prior experience is required! Our coaches work with beginners to teach proper technique and build strength safely.',
  },
  {
    question: 'What are the training fees?',
    answer: 'Contact us for current membership rates. We offer monthly memberships and drop-in options.',
  },
  {
    question: 'How do I register for competitions?',
    answer: 'Competition registration is handled through our team. Reach out to us and we\'ll guide you through the process.',
  },
];
---

<Layout title="Contact">
  <Hero
    title="Contact Us"
    subtitle="Get in touch with us. We'd love to hear from you."
    backgroundImage="/images/gallery-4.jpg"
    imagePosition="center top"
  />

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div>
          <SectionHeader title="Send Us a Message" centered={false} />
          <form class="space-y-6">
            <div class="grid sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-text-secondary mb-2">
                  Name
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded-lg text-white placeholder-text-muted focus:outline-none focus:border-blood-red transition-colors"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-text-secondary mb-2">
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded-lg text-white placeholder-text-muted focus:outline-none focus:border-blood-red transition-colors"
                  placeholder="your@email.com"
                />
              </div>
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-text-secondary mb-2">
                Subject
              </label>
              <select
                id="subject"
                name="subject"
                class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded-lg text-white focus:outline-none focus:border-blood-red transition-colors"
              >
                <option value="general">General Inquiry</option>
                <option value="training">Training & Membership</option>
                <option value="competition">Competition Information</option>
                <option value="sponsorship">Sponsorship</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-text-secondary mb-2">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded-lg text-white placeholder-text-muted focus:outline-none focus:border-blood-red transition-colors resize-none"
                placeholder="How can we help you?"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full px-6 py-4 bg-blood-red text-white font-heading text-lg tracking-wide rounded-lg hover:bg-blood-red-light transition-colors"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact Info & FAQ -->
        <div>
          <!-- Contact Info -->
          <SectionHeader title="Contact Information" centered={false} />
          <div class="space-y-4 mb-12">
            {contactInfo.map(info => (
              <div class="flex items-start gap-4 p-4 bg-dark-card rounded-xl border border-dark-border">
                <div class="w-12 h-12 bg-blood-red/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-blood-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={info.icon} />
                  </svg>
                </div>
                <div>
                  <h3 class="font-heading text-lg text-white">{info.title}</h3>
                  <p class="text-text-secondary">{info.value}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- FAQ -->
          <SectionHeader title="Frequently Asked Questions" centered={false} />
          <div class="space-y-4">
            {faqs.map(faq => (
              <details class="group bg-dark-card rounded-xl border border-dark-border">
                <summary class="flex items-center justify-between p-4 cursor-pointer">
                  <span class="font-heading text-white">{faq.question}</span>
                  <svg class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-4 pb-4">
                  <p class="text-text-secondary">{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section (Placeholder) -->
  <section class="py-20 bg-dark-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        title="Find Us"
        subtitle="Visit our training facility."
      />
      <div class="bg-dark-card rounded-2xl border border-dark-border h-96 flex items-center justify-center">
        <div class="text-center">
          <svg class="w-16 h-16 text-text-muted mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <p class="text-text-muted font-heading">Map Integration</p>
          <p class="text-text-muted text-sm">Interactive map coming soon</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
