---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';

const galleryImages = [
  { src: '/images/gallery-1.jpg', title: 'Competition Action', category: 'competitions' },
  { src: '/images/gallery-2.jpg', title: 'Match Intensity', category: 'competitions' },
  { src: '/images/gallery-3.jpg', title: 'Victory Moment', category: 'competitions' },
  { src: '/images/gallery-4.jpg', title: 'Team Spirit', category: 'team' },
  { src: '/images/gallery-5.jpg', title: 'Training Session', category: 'training' },
  { src: '/images/gallery-6.jpg', title: 'Championship Match', category: 'competitions' },
];
---

<Layout title="Gallery">
  <Hero
    title="Gallery"
    subtitle="Photos from competitions, training sessions, and team events."
    backgroundImage="/images/gallery-1.jpg"
    imagePosition="center top"
  />

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        title="Photo Gallery"
        subtitle="Capturing the action and spirit of MK Armwrestling."
      />

      <!-- Gallery Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {galleryImages.map((image) => (
          <div class="group relative rounded-xl overflow-hidden border border-dark-border hover:border-blood-red transition-all cursor-pointer">
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={image.src}
                alt={image.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
              <div class="absolute bottom-0 left-0 right-0 p-4">
                <h3 class="font-heading text-lg text-white">{image.title}</h3>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Image Section -->
  <section class="py-20 bg-dark-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        title="The Grip"
        subtitle="Where it all begins - the battle starts at the grip."
      />
      <div class="max-w-4xl mx-auto">
        <div class="rounded-2xl overflow-hidden border border-dark-border">
          <img
            src="/images/grip.jpg"
            alt="Arm wrestling grip close-up"
            class="w-full h-auto"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- More Photos CTA -->
  <section class="py-16 bg-blood-red">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl sm:text-4xl text-white mb-4">
        Follow Us for More
      </h2>
      <p class="text-white/80 mb-6">
        See more photos and videos on our social media channels.
      </p>
      <div class="flex gap-4 justify-center">
        <a
          href="#"
          class="inline-flex items-center justify-center px-6 py-3 bg-white text-blood-red font-heading tracking-wide rounded-lg hover:bg-gray-100 transition-colors"
        >
          Instagram
        </a>
        <a
          href="#"
          class="inline-flex items-center justify-center px-6 py-3 bg-transparent text-white border border-white font-heading tracking-wide rounded-lg hover:bg-white/10 transition-colors"
        >
          Facebook
        </a>
      </div>
    </div>
  </section>
</Layout>
