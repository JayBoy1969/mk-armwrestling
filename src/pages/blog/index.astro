---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { getAllPosts } from '../../lib/blog';
import { getKV } from '../../lib/runtime';

export const prerender = false;

const posts = await getAllPosts(getKV());
const featuredPost = posts[0];
const recentPosts = posts.slice(1);
---

<Layout title="Blog">
  <Hero
    title="Blog"
    subtitle="News, training tips, competition recaps, and updates from MK Armwrestling."
    backgroundImage="/images/training.jpg"
    imagePosition="center top"
  />

  {featuredPost && (
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionHeader
          title="Featured"
          subtitle="Our latest news and updates."
        />
        <a href={`/blog/${featuredPost.slug}`} class="block group">
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div class="rounded-xl overflow-hidden border border-dark-border group-hover:border-blood-red transition-colors">
              <img src={featuredPost.image} alt={featuredPost.title} class="w-full h-full object-cover" />
            </div>
            <div>
              <span class="text-blood-red font-heading tracking-wider">{new Date(featuredPost.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
              <h2 class="font-heading text-3xl sm:text-4xl text-white mt-2 mb-4 group-hover:text-blood-red transition-colors">
                {featuredPost.title}
              </h2>
              <p class="text-text-secondary mb-6 leading-relaxed">
                {featuredPost.excerpt}
              </p>
              <span class="inline-flex items-center text-blood-red font-heading tracking-wide group-hover:gap-2 transition-all">
                Read Full Article
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  {recentPosts.length > 0 && (
    <section class="py-20 bg-dark-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionHeader
          title="Recent Posts"
          subtitle="Catch up on the latest from our team."
        />
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {recentPosts.map(post => (
            <a href={`/blog/${post.slug}`} class="bg-dark-card rounded-xl border border-dark-border overflow-hidden hover:border-blood-red transition-all group">
              {post.image && (
                <div class="aspect-video overflow-hidden">
                  <img
                    src={post.image}
                    alt={post.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
              )}
              <div class="p-6">
                <span class="text-blood-red font-heading text-sm tracking-wider">
                  {new Date(post.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                </span>
                <h3 class="font-heading text-2xl text-white mt-2 mb-3 group-hover:text-blood-red transition-colors">
                  {post.title}
                </h3>
                <p class="text-text-secondary text-sm leading-relaxed mb-4">
                  {post.excerpt}
                </p>
                <span class="inline-flex items-center text-blood-red font-heading text-sm tracking-wide">
                  Read More
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {posts.length === 0 && (
    <section class="py-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-text-secondary text-lg">No blog posts yet. Check back soon!</p>
      </div>
    </section>
  )}

  <section class="py-16 bg-blood-red">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl sm:text-4xl text-white mb-4">
        Stay Updated
      </h2>
      <p class="text-white/80 mb-6">
        Follow us on social media for the latest news, training content, and competition updates.
      </p>
      <div class="flex justify-center gap-4">
        <a
          href="https://www.facebook.com/groups/5536349236"
          class="inline-flex items-center justify-center px-6 py-3 bg-white text-blood-red font-heading tracking-wide rounded-lg hover:bg-gray-100 transition-colors"
        >
          Facebook
        </a>
        <a
          href="https://www.instagram.com/mkarmwrestling/"
          class="inline-flex items-center justify-center px-6 py-3 bg-white text-blood-red font-heading tracking-wide rounded-lg hover:bg-gray-100 transition-colors"
        >
          Instagram
        </a>
        <a
          href="https://www.youtube.com/@miltonkeynesarmwrestling"
          class="inline-flex items-center justify-center px-6 py-3 bg-white text-blood-red font-heading tracking-wide rounded-lg hover:bg-gray-100 transition-colors"
        >
          YouTube
        </a>
      </div>
    </div>
  </section>
</Layout>
