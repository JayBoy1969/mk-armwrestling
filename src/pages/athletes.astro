---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import AthleteCard from '../components/AthleteCard.astro';

const heroImage = '/images/training.jpg';

// TODO: replace each empty `instagram` with the athlete's Instagram profile URL
// (e.g. 'https://instagram.com/their_handle') as they become available.
const athletes = [
  {
    name: 'Ryan Finnerty',
    achievements: ['Club Management', 'Multiple top-8 World finishes'],
    instagram: '',
  },
  {
    name: 'Chris Lewis',
    image: '/images/Chris Lewis.jpg',
    achievements: ['Club Management'],
    instagram: 'https://www.instagram.com/chrislewis_aw/',
  },
  {
    name: 'Jason Brooks',
    image: '/images/Jason Brooks.jpg',
    achievements: ['Club Management', 'Multiple top-8 World finishes'],
    instagram: '',
  },
  {
    name: 'Mark Waldon',
    image: '/images/Mark Waldon.jpg',
    achievements: ['Multiple medallist'],
    instagram: 'https://www.instagram.com/mumm_ra_waldon/',
  },
  {
    name: 'Joseph Finnerty',
    achievements: ['IFA Junior -18 World Champion (2024)', 'European Champion (2025)', 'PAA -78kg Runner-up (2025)'],
    instagram: 'https://www.instagram.com/josephfinnerty7/',
  },
  {
    name: 'Elijah Finnerty',
    achievements: ['IFA -15 World Junior Bronze (2024)'],
    instagram: 'https://www.instagram.com/elijahin_finnertyy/',
  },
  {
    name: 'James Price',
    image: '/images/James Price.jpg',
    achievements: ['Club Competitor'],
    instagram: '',
  },
  {
    name: 'Tom Ballard',
    achievements: ['Club Competitor'],
    instagram: '',
  },
  {
    name: 'Adam Partyka',
    image: '/images/Adam Partyka .jpg',
    achievements: ['Club Competitor'],
    instagram: 'https://www.instagram.com/4d4m_aw/',
  },
  {
    name: 'Steven Sowah',
    image: '/images/Steven Sowah.jpg',
    achievements: ['Club Competitor'],
    instagram: '',
  },
  {
    name: 'Przemyslaw Charkiewicz',
    achievements: ['Club Competitor'],
    instagram: '',
  },
  {
    name: 'Mathew Preston',
    achievements: ['Club Competitor'],
    instagram: '',
  },
  {
    name: 'Cosmin Boticas',
    achievements: ['Club Competitor'],
    instagram: 'https://www.instagram.com/cosminboticas/',
  },
];
---

<Layout
  title="Athletes"
  description="Meet the MK Armwrestling team — the competitors and club management representing Milton Keynes Armwrestling at events across the UK and beyond."
>
  <Hero
    title="Our Athletes"
    subtitle="Meet the dedicated competitors who represent MK Armwrestling at competitions around the world."
    backgroundImage={heroImage}
    imagePosition="center center"
  />

  <!-- Athletes Grid -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        title="The Team"
        subtitle="From rising stars to seasoned champions, our athletes compete with passion and dedication."
      />

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {athletes.map(athlete => (
          <AthleteCard {...athlete} />
        ))}
      </div>
    </div>
  </section>

  <!-- Join Section -->
  <section class="py-20 bg-dark-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <SectionHeader
        title="Want to Join the Team?"
        subtitle="We're always looking for dedicated athletes who want to take their arm wrestling to the next level."
      />
      <p class="text-text-secondary mb-8 max-w-2xl mx-auto">
        Whether you're an experienced competitor or just getting started, MK Armwrestling welcomes
        athletes of all skill levels. Our experienced coaches will help you develop your technique
        and reach your full potential.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-8 py-4 bg-blood-red text-white font-heading text-lg tracking-wide rounded-lg hover:bg-blood-red-light transition-colors"
      >
        Get In Touch
      </a>
    </div>
  </section>
</Layout>
