---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import AthleteCard from '../components/AthleteCard.astro';

const heroImage = '/images/gallery-2.jpg';

const athletes = [
  {
    name: 'Mark Waldon',
    weightClass: 'Heavyweight',
    image: '/images/Mark Waldon.jpg',
    achievements: ['Club Competitor'],
  },
  {
    name: 'Joseph Finnerty',
    weightClass: 'Middleweight',
    achievements: ['Club Competitor'],
  },
  {
    name: 'Elijah Finnerty',
    weightClass: 'Lightweight',
    achievements: ['Club Competitor'],
  },
  {
    name: 'James Price',
    weightClass: 'Heavyweight',
    image: '/images/James Price.jpg',
    achievements: ['Club Competitor'],
  },
  {
    name: 'Tom Ballard',
    weightClass: 'Middleweight',
    achievements: ['Club Competitor'],
  },
  {
    name: 'Adam Partyka',
    weightClass: 'Heavyweight',
    image: '/images/Adam Partyka .jpg',
    achievements: ['Club Competitor'],
  },
  {
    name: 'Steven Sowah',
    weightClass: 'Light Heavyweight',
    image: '/images/Steven Sowah.jpg',
    achievements: ['Club Competitor'],
  },
  {
    name: 'Przemyslaw Charkiewicz',
    weightClass: 'Heavyweight',
    achievements: ['Club Competitor'],
  },
  {
    name: 'Mathew Preston',
    weightClass: 'Middleweight',
    achievements: ['Club Competitor'],
  },
];

const weightClasses = ['All', 'Super Heavyweight', 'Heavyweight', 'Light Heavyweight', 'Middleweight'];
---

<Layout title="Athletes">
  <Hero
    title="Our Athletes"
    subtitle="Meet the dedicated competitors who represent MK Armwrestling at competitions around the world."
    backgroundImage={heroImage}
    imagePosition="center bottom"
  />

  <!-- Athletes Grid -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        title="The Team"
        subtitle="From rising stars to seasoned champions, our athletes compete with passion and dedication."
      />

      <!-- Filter Buttons -->
      <div class="flex flex-wrap gap-3 justify-center mb-12">
        {weightClasses.map((weightClass, index) => (
          <button
            class={`px-4 py-2 rounded-lg font-heading tracking-wide transition-all ${
              index === 0
                ? 'bg-blood-red text-white'
                : 'bg-dark-card text-text-secondary border border-dark-border hover:border-blood-red'
            }`}
            data-filter={weightClass.toLowerCase().replace(' ', '-')}
          >
            {weightClass}
          </button>
        ))}
      </div>

      <!-- Athletes Grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {athletes.map(athlete => (
          <AthleteCard {...athlete} />
        ))}
      </div>
    </div>
  </section>

  <!-- Join Section -->
  <section class="py-20 bg-dark-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <SectionHeader
        title="Want to Join the Team?"
        subtitle="We're always looking for dedicated athletes who want to take their arm wrestling to the next level."
      />
      <p class="text-text-secondary mb-8 max-w-2xl mx-auto">
        Whether you're an experienced competitor or just getting started, MK Armwrestling welcomes
        athletes of all skill levels. Our experienced coaches will help you develop your technique
        and reach your full potential.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-8 py-4 bg-blood-red text-white font-heading text-lg tracking-wide rounded-lg hover:bg-blood-red-light transition-colors"
      >
        Get In Touch
      </a>
    </div>
  </section>
</Layout>
