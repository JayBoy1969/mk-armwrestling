---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import AthleteCard from '../components/AthleteCard.astro';
import Button from '../components/Button.astro';
import { getAllPosts } from '../lib/blog';
import { getKV } from '../lib/runtime';

export const prerender = false;

// 3 most recent published posts for the "Latest News & Features" section.
const latestPosts = (await getAllPosts(getKV())).slice(0, 3);

const featuredAthletes = [
  {
    name: 'Mark Waldon',
    weightClass: 'Heavyweight',
    image: '/images/Mark Waldon.jpg',
    achievements: ['Club Competitor'],
  },
  {
    name: 'Adam Partyka',
    weightClass: 'Heavyweight',
    image: '/images/Adam Partyka .jpg',
    achievements: ['Club Competitor'],
  },
  {
    name: 'Steven Sowah',
    weightClass: 'Light Heavyweight',
    image: '/images/Steven Sowah.jpg',
    achievements: ['Club Competitor'],
  },
];

const stats = [
  { value: '50+', label: 'Athletes' },
  { value: '100+', label: 'Competitions' },
  { value: '25+', label: 'Champions' },
  { value: '10+', label: 'Years' },
];

// Hero background video, hosted on a Cloudflare R2 public bucket.
const PROMO_VIDEO_URL = 'https://pub-e8926451d30f4159b429239045824a77.r2.dev/promo.mp4';
---

<Layout title="Home">
  <!-- Hero Section -->
  <Hero
    title="Strength. Power. Victory."
    subtitle="Welcome to MK Armwrestling - where champions are made. Join us in the pursuit of excellence in the sport of arm wrestling."
    showCta={true}
    backgroundVideo={PROMO_VIDEO_URL}
    backgroundImage="/images/hero.jpg"
    imagePosition="center top"
    videoOnce={true}
  />

  <!-- Stats Section -->
  <section class="py-16 bg-dark-surface border-y border-dark-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map(stat => (
          <div class="text-center">
            <div class="font-heading text-5xl sm:text-6xl text-blood-red mb-2">{stat.value}</div>
            <div class="text-text-secondary font-heading tracking-wider">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest News & Features -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        title="Latest News & Features"
        subtitle="Stay up to date with MK Armwrestling."
      />
      {latestPosts.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {latestPosts.map(post => (
            <a href={`/blog/${post.slug}`} class="bg-dark-card rounded-xl border border-dark-border overflow-hidden hover:border-blood-red transition-all group">
              {post.image && (
                <div class="aspect-video overflow-hidden">
                  <img
                    src={post.image}
                    alt={post.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
              )}
              <div class="p-6">
                <span class="text-blood-red font-heading text-sm tracking-wider">
                  {new Date(post.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                </span>
                <h3 class="font-heading text-2xl text-white mt-2 mb-3 group-hover:text-blood-red transition-colors">
                  {post.title}
                </h3>
                <p class="text-text-secondary text-sm leading-relaxed mb-4">{post.excerpt}</p>
                <span class="inline-flex items-center text-blood-red font-heading text-sm tracking-wide">
                  Read More
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="max-w-2xl mx-auto text-center py-8">
          <p class="text-text-secondary text-lg">
            No news just yet &mdash; we're busy training. Check back soon for competition recaps,
            athlete features, and updates from the club.
          </p>
        </div>
      )}
      <div class="text-center mt-12">
        <Button href="/blog" variant="outline">View All Posts</Button>
      </div>
    </div>
  </section>

  <!-- Featured Athletes -->
  <section class="py-20 bg-dark-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        title="Featured Athletes"
        subtitle="Meet some of our top competitors who represent MK Armwrestling."
      />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredAthletes.map(athlete => (
          <AthleteCard {...athlete} />
        ))}
      </div>
      <div class="text-center mt-12">
        <Button href="/athletes">View All Athletes</Button>
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <SectionHeader title="About MK Armwrestling" centered={false} />
          <p class="text-text-secondary mb-6">
            MK Armwrestling is dedicated to promoting and developing the sport of arm wrestling.
            Our team of experienced athletes and coaches work together to train the next generation
            of champions while competing at the highest levels.
          </p>
          <p class="text-text-secondary mb-8">
            Whether you're a seasoned competitor or just starting out, MK Armwrestling welcomes
            all who share our passion for the sport.
          </p>
          <Button href="/about" variant="outline">Learn More</Button>
        </div>
        <div class="rounded-2xl overflow-hidden border border-dark-border min-h-[400px]">
          <img src="/images/gallery-2.jpg" alt="Arm wrestling action" class="w-full h-full object-cover" style="object-position: center center;" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-blood-red">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-4xl sm:text-5xl text-white mb-6">
        Ready to Join the Team?
      </h2>
      <p class="text-white/80 text-lg mb-8 max-w-2xl mx-auto">
        Whether you're looking to compete or just want to train, we'd love to hear from you.
        Get in touch and start your arm wrestling journey today.
      </p>
      <Button href="/contact" variant="secondary" size="lg">Contact Us</Button>
    </div>
  </section>
</Layout>
